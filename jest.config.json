{
  "testTimeout": 10000,
  "collectCoverage": true,
  "coverageDirectory": "coverage",
  "errorOnDeprecated": true,
  "moduleFileExtensions": [
    "js",
    "json",
    "jsx",
    "ts",
    "tsx",
    "node"
  ],
  "roots": [
    "tests"
  ],
  "testEnvironment": "node",
  "testLocationInResults": true,
  "transform": {
    "^.+\\.(t|j)sx?$": "ts-jest"
  }
}