{
  "name": "@elek-io/core",
  "version": "0.17.0",
  "description": "Handles core functionality of elek.io Projects like file IO and version control.",
  "homepage": "https://elek.io",
  "repository": "https://github.com/elek-io/core",
  "bugs": {
    "url": "https://github.com/elek-io/core/issues"
  },
  "type": "module",
  "bin": {
    "elek": "./dist/cli/index.cli.mjs"
  },
  "files": [
    "dist/node",
    "dist/browser",
    "dist/astro",
    "dist/cli"
  ],
  "exports": {
    ".": {
      "node": {
        "import": {
          "types": "./dist/node/index.node.d.mts",
          "default": "./dist/node/index.node.mjs"
        }
      },
      "import": {
        "types": "./dist/browser/index.browser.d.ts",
        "default": "./dist/browser/index.browser.js"
      }
    },
    "./astro": {
      "import": {
        "types": "./dist/astro/index.astro.d.mts",
        "default": "./dist/astro/index.astro.mjs"
      }
    }
  },
  "pnpm": {
    "overrides": {}
  },
  "scripts": {
    "lint": "eslint",
    "check-types": "tsc --noEmit",
    "check-format": "prettier --check . || exit 0",
    "format": "prettier --write .",
    "dev": "vitest",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "build": "tsdown",
    "release": "changeset publish"
  },
  "dependencies": {
    "@hono/node-server": "1.19.12",
    "@hono/zod-openapi": "1.2.4",
    "@scalar/hono-api-reference": "0.10.5",
    "@sindresorhus/slugify": "3.0.0",
    "fs-extra": "11.3.4",
    "hono": "4.12.9",
    "mime": "4.1.0",
    "p-queue": "9.1.0",
    "semver": "7.7.4",
    "uuid": "13.0.0",
    "winston": "3.19.0",
    "winston-daily-rotate-file": "5.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@commander-js/extra-typings": "14.0.0",
    "@eslint/js": "10.0.1",
    "@faker-js/faker": "10.4.0",
    "@tsconfig/node24": "24.0.4",
    "@tsconfig/strictest": "2.0.8",
    "@types/fs-extra": "11.0.4",
    "@types/mdast": "4.0.4",
    "@types/node": "24.12.0",
    "@types/semver": "7.7.1",
    "@vitest/coverage-v8": "4.1.2",
    "astro": "6.3.8",
    "chokidar": "5.0.0",
    "code-block-writer": "13.0.3",
    "commander": "14.0.3",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.4.0",
    "jiti": "2.6.1",
    "prettier": "3.8.1",
    "tsdown": "0.21.7",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0",
    "vitest": "4.1.2"
  },
  "peerDependencies": {
    "astro": ">=6.0.0",
    "dugite": "3.2.0"
  },
  "peerDependenciesMeta": {
    "astro": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
