  "license": "",
  "scripts": {
    "lint": "yarn eslint src/**",
    "test": "NODE_ENV=test yarn ts-mocha -p tsconfig.json test/**/*.ts",
    "test:full": "echo \"Running tests for version $npm_package_version...\" && yarn build && yarn lint && yarn test",
    "build": "rm -rf ./dist && tsc",
    "prepare": "yarn build",
    "preversion": "yarn test:full",
    "postversion": "git push --tags && yarn publish . --tag $npm_package_version && git push && echo \"Successfully released version $npm_package_version!\""
  },
  "devDependencies": {
    "@types/chai": "^4.2.14",
    "@types/cheerio": "^0.22.22",
    "@types/fs-extra": "^9.0.4",
    "@types/highlight.js": "^10.1.0",
    "@types/lodash": "^4.14.165",
    "@types/markdown-it": "^10.0.3",
    "@types/mocha": "^8.0.4",
    "@types/node": "^14.14.10",
    "@types/pino": "^6.3.4",
    "@types/sonic-boom": "^0.7.0",
    "@types/uuid": "^8.3.0",
    "@typescript-eslint/eslint-plugin": "^4.9.0",
    "@typescript-eslint/parser": "^4.9.0",
    "chai": "^4.2.0",
    "eslint": "^7.15.0",
    "mocha": "^8.2.1",
    "pino-pretty": "^4.3.0",
    "ts-mocha": "^8.0.0",
    "typescript": "^4.1.2"
  },
