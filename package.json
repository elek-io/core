{
  "name": "@elek.io/core",
  "description": "",
  "version": "0.0.10-alpha",
  "main": "dist/index.js",
  "files": [
    "dist/**/*"
  ],
  "types": "dist/index.d.ts",
  "homepage": "https://github.com/elek-io/core",
  "repository": "git@github.com:elek-io/core.git",
