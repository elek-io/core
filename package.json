{
  "name": "@elek-io/core",
  "version": "0.22.0",
  "description": "Handles core functionality of elek.io Projects like file IO and version control.",
  "homepage": "https://elek.io",
  "repository": "https://github.com/elek-io/core",
  "bugs": {
    "url": "https://github.com/elek-io/core/issues"
  },
  "type": "module",
  "bin": {
    "elek": "./dist/cli/index.cli.mjs"
  },
  "files": [
    "dist/node",
    "dist/browser",
    "dist/astro",
    "dist/cli",
    "docs"
  ],
  "exports": {
    ".": {
      "node": {
        "import": {
          "types": "./dist/node/index.node.d.mts",
          "default": "./dist/node/index.node.mjs"
        }
      },
      "import": {
        "types": "./dist/browser/index.browser.d.ts",
        "default": "./dist/browser/index.browser.js"
      }
    },
    "./astro": {
      "import": {
        "types": "./dist/astro/index.astro.d.mts",
        "default": "./dist/astro/index.astro.mjs"
      }
    }
  },
  "scripts": {
    "lint": "eslint",
    "check-types": "tsc --noEmit",
    "check-format": "prettier --check .",
    "format": "prettier --write .",
    "dev": "vitest",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "build": "tsdown",
    "release": "changeset publish"
  },
  "dependencies": {
    "@hono/node-server": "2.0.5",
    "@hono/zod-openapi": "1.4.0",
    "@scalar/hono-api-reference": "0.11.4",
    "@sindresorhus/slugify": "3.0.0",
    "fs-extra": "11.3.5",
    "hono": "4.12.26",
    "mime": "4.1.0",
    "p-queue": "9.3.0",
    "semver": "7.8.4",
    "uuid": "14.0.0",
    "winston": "3.19.0",
    "winston-daily-rotate-file": "5.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@commander-js/extra-typings": "15.0.0",
    "@eslint/js": "10.0.1",
    "@faker-js/faker": "10.5.0",
    "@tsconfig/node24": "24.0.4",
    "@tsconfig/strictest": "2.0.8",
    "@types/fs-extra": "11.0.4",
    "@types/mdast": "4.0.4",
    "@types/node": "24.13.2",
    "@types/semver": "7.7.1",
    "@vitest/coverage-v8": "4.1.9",
    "astro": "6.4.8",
    "chokidar": "5.0.0",
    "code-block-writer": "13.0.3",
    "commander": "15.0.0",
    "dugite": "3.2.2",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.6.0",
    "jiti": "2.7.0",
    "prettier": "3.8.4",
    "tsdown": "0.22.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.9",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "astro": "^6.0.0",
    "dugite": "^3.0.0",
    "zod": "^4.3.6"
  },
  "peerDependenciesMeta": {
    "astro": {
      "optional": true
    }
  },
  "packageManager": "pnpm@11.5.0"
}
